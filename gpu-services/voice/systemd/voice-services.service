[Unit]
Description=HiveWright Voice Services (STT + TTS + voiceprint)
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/hivewrightv2-voice-ea/gpu-services/voice
Environment="CUDA_VISIBLE_DEVICES=0"
ExecStart=%h/.local/bin/uv run uvicorn voice_services.server:app --host 0.0.0.0 --port 8790
Restart=on-failure
RestartSec=10

[Install]
WantedBy=default.target
