{
  "name": "hivewrightv2",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "npm run check:route-auth && eslint",
    "typecheck": "tsc --noEmit",
    "check:route-auth": "tsx scripts/check-route-auth.ts",
    "check:landed-state": "tsx scripts/verify-landed-state.ts",
    "public:scan": "tsx scripts/public-readiness-scan.ts",
    "security:scan": "tsx scripts/security-scan.ts",
    "dispatcher": "tsx src/dispatcher/index.ts",
    "initiative:run-once": "tsx scripts/run-initiative-schedule.ts",
    "initiative:live-proof:readiness": "tsx scripts/inspect-dormant-goal-live-proof.ts",
    "initiative:dormant-goal:fixture": "tsx scripts/setup-dormant-goal-proof-fixture.ts",
    "test:initiative:dormant-goal": "tsx scripts/run-dormant-goal-verification.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:app": "tsx -r dotenv/config scripts/migrate-app-db.ts",
    "db:push": "drizzle-kit push",
    "auth:owner-reset-local": "tsx scripts/reset-owner-session.ts",
    "auth:owner-smoke": "tsx scripts/run-owner-session-smoke.ts",
    "auth:owner-smoke:local": "tsx scripts/run-owner-session-local-smoke.ts",
    "qa:operations-map:parked-fixture": "tsx scripts/setup-operations-map-parked-qa-fixture.ts",
    "check:migrations": "tsx scripts/check-drizzle-journal.ts",
    "security:scan:daily": "bash scripts/run-security-scan.sh daily",
    "security:scan:weekly": "bash scripts/run-security-scan.sh weekly",
    "test": "npm run check:migrations && vitest run --maxWorkers=1",
    "test:reembed": "vitest run tests/memory/reembed.test.ts",
    "test:watch": "vitest",
    "test:setup-db": "tsx scripts/setup-test-db.ts",
    "notifier:verify": "tsx scripts/verify-outbound-notifier.ts",
    "notifier:live-smoke": "tsx scripts/send-outbound-notifier-live-smoke.ts",
    "build:dispatcher": "esbuild src/dispatcher/index.ts --bundle --platform=node --format=cjs --outfile=dispatcher-bundle.js --external:postgres --external:chokidar --external:discord.js --external:@discordjs/* --external:zlib-sync",
    "hivewright:update": "tsx scripts/update-hivewright.ts"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@base-ui/react": "^1.3.0",
    "@serwist/next": "^9.5.7",
    "@tanstack/react-query": "^5.99.0",
    "@types/nodemailer": "^7.0.11",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.14.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.7",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "serwist": "^9.5.7",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "postcss": "8.5.12"
  }
}
