DATABASE_URL=postgres://hivewright:change-me@localhost:5432/hivewright
ENCRYPTION_KEY=generate-a-random-32-byte-base64-value
PORT=3002
OLLAMA_GENERATION_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Shared bearer for trusted internal callers such as the dispatcher/EA path.
# Generate with `openssl rand -hex 32`, keep the live secret only in the
# runtime env source, then restart the dashboard and use
# `./scripts/deferred-restart-dispatcher.sh 10` for dispatcher pickup.
INTERNAL_SERVICE_TOKEN=generate-a-random-32-byte-hex-token
HIVES_WORKSPACE_ROOT=/absolute/path/outside/this/repo/hives
# Comma-separated origins that Next.js should allow in development, for
# example an HTTPS tunnel or private network host used from a phone.
HIVEWRIGHT_ALLOWED_DEV_ORIGINS=
# Optional extra env file sourced by start-dispatcher.sh after .env. Use this
# only for local operator-managed runtime credentials that must reach spawned
# agent CLIs.
HIVEWRIGHT_EXTRA_ENV_FILE=
# Voice EA: the GPU services URL is configured via the `voice-ea` connector
# in the dashboard's Connectors page (per-hive, takes effect immediately
# without an env reload). VOICE_SERVICES_URL below is an optional fallback
# for tests / fresh dev boxes that haven't installed the connector yet.
# VOICE_SERVICES_URL=http://voice-services.example.local:8790
